# Sourced from zshenv, which runs before zshrc. Nix has to be set up this
# early so that nix-installed tools are on PATH before direnv, the p10k
# instant prompt, and oh-my-zsh run.
if [[ -f /nix/setup-nix.sh ]]; then
  source /nix/setup-nix.sh
fi

# path_enforce_order runs later (zprofile, then zshrc) and forces .bin and
# .local/bin ahead of this, leaving nix third — matching the shared order.
path_prepend "$HOME/.nix-profile/bin"

# config/mise is symlinked wholesale, so a conf.d file there would also apply
# on the mac. This env var is the only machine-specific way to disable a tool.
# Must be set before zshrc.ts runs `mise activate`.
export MISE_DISABLE_TOOLS="npm:@anthropic-ai/claude-code"

# Turn off oh-my-zsh's built-in auto-update; zshrc.2s drives it instead, through
# a network proxy helper that the built-in update cannot use.
export OMZ_UPDATE_MODE=disabled
